{
  "name": "xuanlin-overmind",
  "version": "2.0.0",
  "description": "CC 的外挂认知引擎 — 五层记忆 · 知识图谱 · 推理 · 预警 · 自进化",
  "author": "玄霖AI (xuanlinAI)",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"<INSTALL_DIR>/inject.js\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"<INSTALL_DIR>/inject.js\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"<INSTALL_DIR>/consolidate.js\""
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "ctxproxy": {
      "type": "stdio",
      "command": "python",
      "args": ["<INSTALL_DIR>/daemon.py"],
      "env": {}
    }
  }
}
